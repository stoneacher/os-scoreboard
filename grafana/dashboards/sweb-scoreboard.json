      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "first_scores = from(bucket: \"${bucket}\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"team_scoreboard\" and r._field == \"score\")\n  |> filter(fn: (r) => exists r.team_id)\n  |> group(columns: [\"team_id\", \"display_name\"])\n  |> first()\n  |> rename(columns: {_value: \"start_score\"})\n  |> keep(columns: [\"team_id\", \"display_name\", \"start_score\"])\n\nlast_scores = from(bucket: \"${bucket}\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"team_scoreboard\" and r._field == \"score\")\n  |> filter(fn: (r) => exists r.team_id)\n  |> group(columns: [\"team_id\", \"display_name\"])\n  |> last()\n  |> rename(columns: {_value: \"end_score\"})\n  |> keep(columns: [\"team_id\", \"display_name\", \"end_score\"])\n\njoin(tables: {first: first_scores, last: last_scores}, on: [\"team_id\", \"display_name\"])\n  |> map(fn: (r) => ({display_name: r.display_name, team_id: r.team_id, start_score: r.start_score, end_score: r.end_score, score_delta: r.end_score - r.start_score}))\n  |> sort(columns: [\"score_delta\"], desc: true)\n  |> limit(n: 20)",
          "refId": "A"
        }
      ],
      "title": "Top Score Changes In The Last 24 Hours",
      "type": "table"
